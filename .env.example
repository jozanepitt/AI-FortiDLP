# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY
CLAUDE_MODEL=claude-sonnet-4-5

# FortiDLP Event Stream
# Base URL of your tenant (from the stream URL, e.g. https://XXXX.reveal.nextdlp.com)
FORTIDLP_BASE_URL=https://your-tenant.reveal.nextdlp.com
# Stream ID UUID — from Integrations > Event Streaming in the console
FORTIDLP_STREAM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Stream access token — generated from the stream row > ... > Generate access token
FORTIDLP_STREAM_TOKEN=eyJ...

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
